// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN       // administrador
  SUPERVISOR  // supervisor
  SELLER      // vendedor
}


model Provider {
  id        String    @id @default(uuid())
  name      String    @unique
  phone     String
  createdAt DateTime  @default(now())
  updatedAt DateTime @updatedAt
  products  Product[]
}


model User {
  id        String    @id @default(uuid())
  userCode  Int       @unique //código de usuario unico
  name      String
  email     String    @unique
  phone     String
  password  String
  role      Role      @default(SELLER)
  products  Product[]
}

model Product {
  id           String   @id @default(uuid())      // id automático (UUID)
  sku          String   @unique                    // sku único
  name         String
  description  String?                              
  costPrice    Float
  salePrice    Float
  stock        Int
  category     String?
  brand        String?
  createdAt   DateTime @default(now())
  createdBy   String   // <- el id del usuario que lo creó
  user        User      @relation(fields: [createdBy], references: [id])

  // relación con proveedor (puede ser opcional)
  providerId  String?
  provider    Provider? @relation(fields: [providerId], references: [id])
}


