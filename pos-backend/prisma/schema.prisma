generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(uuid())
  userCode        Int?            @unique
  name            String
  email           String          @unique
  phone           String
  password        String
  role            Role            @default(SELLER)
  createdAt       DateTime        @default(now())
  cashBoxesClosed CashBox[]       @relation("CashBoxClosedBy")
  cashBoxesOpened CashBox[]       @relation("CashBoxOpenedBy")
  products        Product[]
  priceHistory    PriceHistory[]
  approvedReturns Return[]        @relation("ApprovedReturns")
  Sale            Sale[]
  stockMovements  StockMovement[]

  @@map("User")
}

model Cliente {
  id_cliente       Int         @id @default(autoincrement())
  tipo_cliente     TipoCliente @default(PERSONA)
  nombre           String
  telefono         String
  genero           String?
  fecha_nacimiento DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  Sale             Sale[]
}

model Provider {
  name           String
  createdAt      DateTime        @default(now())
  phone          String
  updatedAt      DateTime        @updatedAt
  id_provider    Int             @id @default(autoincrement())
  Product        Product[]
  stockMovements StockMovement[]
}

model Product {
  id             String          @id @default(uuid())
  sku            String          @unique
  name           String
  salePrice      Float
  costPrice      Float
  createdAt      DateTime        @default(now())
  description    String?
  brand          String?
  category       String?
  stock          Int
  createdBy      String
  providerId     Int?
  user           User            @relation(fields: [createdBy], references: [id])
  provider       Provider?       @relation(fields: [providerId], references: [id_provider])
  priceHistory   PriceHistory[]
  returnItems    ReturnItem[]
  saleItems      SaleItem[]
  stockMovements StockMovement[]
}

model PaymentMethod {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  isCash       Boolean       @default(false)
  expenses     Expense[]
  salePayments SalePayment[]
}

model CashBox {
  id            Int           @id @default(autoincrement())
  openedAt      DateTime      @default(now())
  closedAt      DateTime?
  openedBy      String
  closedBy      String?
  initialAmount Float
  closedAmount  Float?
  status        CashBoxStatus @default(OPEN)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  cashCount     Json?
  nostes        String?
  closedByUser  User?         @relation("CashBoxClosedBy", fields: [closedBy], references: [id])
  openedByUser  User          @relation("CashBoxOpenedBy", fields: [openedBy], references: [id])
  expenses      Expense[]
  sales         Sale[]        @relation("box_sales")
}

model Sale {
  id             String          @id @default(uuid())
  sellerId       String
  clientId       Int?
  total          Float
  totalPaid      Float           @default(0)
  balance        Float           @default(0)
  paymentStatus  PaymentStatus   @default(PENDING)
  createdAt      DateTime        @default(now())
  cashBoxId      Int?
  createdBy      String?
  returns        Return[]
  items          SaleItem[]
  payments       SalePayment[]
  cashBox        CashBox?        @relation("box_sales", fields: [cashBoxId], references: [id])
  client         Cliente?        @relation(fields: [clientId], references: [id_cliente])
  seller         User            @relation(fields: [sellerId], references: [id])
  stockMovements StockMovement[]

  @@map("sales")
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    String
  productId String
  quantity  Int
  unitPrice Float
  subtotal  Float
  product   Product @relation(fields: [productId], references: [id])
  sale      Sale    @relation(fields: [saleId], references: [id])

  @@map("sale_items")
}

model SalePayment {
  id              Int           @id @default(autoincrement())
  saleId          String
  paymentMethodId Int
  amount          Float
  cashBoxId       Int?
  createdAt       DateTime      @default(now())
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  sale            Sale          @relation(fields: [saleId], references: [id])

  @@map("sale_payments")
}

model Expense {
  id              Int           @id @default(autoincrement())
  cashBoxId       Int?
  amount          Float
  concept         String
  paymentMethodId Int
  createdAt       DateTime      @default(now())
  createdBy       String?
  cashBox         CashBox?      @relation(fields: [cashBoxId], references: [id])
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
}

model StockMovement {
  id            Int          @id @default(autoincrement())
  productId     String
  movementType  MovementType
  quantity      Int
  previousStock Int
  newStock      Int
  unitCost      Float?
  providerId    Int?
  saleId        String?
  notes         String?
  reason        String?
  createdBy     String
  createdAt     DateTime     @default(now())
  returnId      Int?
  user          User         @relation(fields: [createdBy], references: [id])
  product       Product      @relation(fields: [productId], references: [id])
  provider      Provider?    @relation(fields: [providerId], references: [id_provider])
  return        Return?      @relation(fields: [returnId], references: [id], onDelete: Cascade)
  sale          Sale?        @relation(fields: [saleId], references: [id])

  @@map("stock_movements")
}

model PriceHistory {
  id        Int      @id @default(autoincrement())
  productId String
  oldPrice  Float
  newPrice  Float
  priceType String
  changedBy String
  changedAt DateTime @default(now())
  notes     String?
  user      User     @relation(fields: [changedBy], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@map("price_history")
}

model Return {
  id             Int             @id @default(autoincrement())
  saleId         String
  returnDate     DateTime        @default(now())
  reason         String
  approvedBy     String
  totalRefunded  Float
  refundMethod   String
  notes          String?
  status         ReturnStatus    @default(PENDING)
  items          ReturnItem[]
  user           User            @relation("ApprovedReturns", fields: [approvedBy], references: [id], onDelete: Cascade)
  sale           Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@map("returns")
}

model ReturnItem {
  id               Int     @id @default(autoincrement())
  returnId         Int
  productId        String
  quantityReturned Int
  unitPrice        Float
  subtotal         Float
  condition        String?
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  return           Return  @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@map("return_items")
}

enum Role {
  ADMIN
  SUPERVISOR
  SELLER
}

enum TipoCliente {
  PERSONA
  EMPRESA
}

enum CashBoxStatus {
  OPEN
  CLOSED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERPAID

  @@map("payment_status")
}

enum MovementType {
  PURCHASE
  SALE
  REPAIR_OUT
  REPAIR_RETURN
  DEMO_OUT
  DEMO_RETURN
  RETURN_IN
  ADJUSTMENT
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}
