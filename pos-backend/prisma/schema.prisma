// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN // administrador
  SUPERVISOR // supervisor
  SELLER // vendedor
}

model User {
  id        String    @id @default(uuid())
  userCode  Int?      @unique //código de usuario unico
  name      String
  email     String    @unique
  phone     String
  password  String
  role      Role      @default(SELLER)
  createdAt DateTime  @default(now())
  products  Product[]
}

model Cliente {
  id_cliente       Int         @id @default(autoincrement())
  tipo_cliente     TipoCliente @default(PERSONA)
  nombre           String
  telefono         String
  genero           String? // Opcional
  fecha_nacimiento DateTime? // Opcional
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

enum TipoCliente {
  PERSONA
  EMPRESA
}

model Provider {
  id_provider Int       @id @default(autoincrement())
  name        String
  phone       String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  Product     Product[]
}

model Product {
  id          String   @id @default(uuid()) // UUID
  sku         String   @unique
  name        String
  description String?
  costPrice   Float
  salePrice   Float
  stock       Int
  category    String?
  brand       String?
  createdAt   DateTime @default(now())
  createdBy   String // id (uuid) del usuario que creó el producto
  user        User     @relation(fields: [createdBy], references: [id])

  // relación con Provider (opcional). providerId es Int para coincidir con Provider.id_provider
  providerId Int?
  provider   Provider? @relation(fields: [providerId], references: [id_provider])

  saleItems SaleItem[]
}

model PaymentMethod {
  id                Int      @id @default(autoincrement())
  name              String   @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  salePayments SalePayment[]
  expenses Expense[]
}

model CashBox {
  id                Int      @id @default(autoincrement())
  openedAt          DateTime @default(now())
  closedAt          DateTime?
  openedBy          String   // User.id (uuid)
  closedBy          String?  // User.id (uuid)
  initialAmount     Float
  closedAmount      Float?   // calculado al cerrar
  status            CashBoxStatus @default(OPEN)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  sales             Sale[]    @relation("box_sales")
  expenses          Expense[] 
}

enum CashBoxStatus {
  OPEN
  CLOSED
}

model Sale {
  id            String      @id @default(uuid())
  sellerId      String      // User.id -> el vendedor (puede elegirse por userCode o id)
  clientId      Int?        // Cliente.id_cliente (opcional)
  total         Float
  createdAt     DateTime    @default(now())
  cashBoxId     Int?        // caja abierta donde se registró la venta
  cashBox       CashBox?    @relation(fields: [cashBoxId], references: [id], name: "box_sales")
  items         SaleItem[]
  payments      SalePayment[]
  createdBy     String?     // quien registró la venta (si difiere del seller)
}

model SaleItem {
  id          Int     @id @default(autoincrement())
  saleId      String
  sale        Sale    @relation(fields: [saleId], references: [id])
  productId   String  // Product.id
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Float   // precio de venta tomado al momento
  subtotal    Float
}

model SalePayment {
  id               Int      @id @default(autoincrement())
  saleId           String
  sale             Sale     @relation(fields: [saleId], references: [id])
  paymentMethodId  Int
  paymentMethod    PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  amount           Float
  cashBoxId        Int?     // si es efectivo y hay caja abierta, linkear
  createdAt        DateTime @default(now())
}

model Expense {
  id             Int      @id @default(autoincrement())
  cashBoxId      Int?     // caja relacionada si fue en efectivo y dentro de una caja
  cashBox        CashBox? @relation(fields: [cashBoxId], references: [id])
  amount         Float
  concept        String
  paymentMethodId Int
  paymentMethod  PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  createdAt      DateTime @default(now())
  createdBy      String? // user id
}