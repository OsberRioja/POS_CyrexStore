generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(uuid())
  userCode        Int?            @unique
  name            String
  email           String          @unique
  phone           String
  password        String
  role            Role            @default(SELLER)
  branchId        Int?
  createdAt       DateTime        @default(now())
  passwordChangeRequired Boolean @default(false)
  deleted         Boolean         @default(false)

  branch       Branch?    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  cashBoxesClosed CashBox[]       @relation("CashBoxClosedBy")
  cashBoxesOpened CashBox[]       @relation("CashBoxOpenedBy")
  products        Product[]
  priceHistory    PriceHistory[]
  approvedReturns Return[]        @relation("ApprovedReturns")
  Sale            Sale[]
  stockMovements  StockMovement[]
  preference      UserPreference?
  expenses    Expense[]
  commissionConfigs CommissionConfig[]
  commissions       Commission[]
  PasswordResetToken PasswordResetToken[]

  @@map("User")
}

model Cliente {
  id_cliente       Int         @id @default(autoincrement())
  tipo_cliente     TipoCliente @default(PERSONA)
  nombre           String
  telefono         String
  genero           String?
  fecha_nacimiento DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  Sale             Sale[]
}

model Provider {
  name           String
  createdAt      DateTime        @default(now())
  phone          String
  updatedAt      DateTime        @updatedAt
  id_provider    Int             @id @default(autoincrement())
  Product        Product[]
  stockMovements StockMovement[]
}

model Product {
  id             String          @id @default(uuid())
  sku            String          @unique
  name           String
  salePrice      Float
  costPrice      Float
  createdAt      DateTime        @default(now())
  description    String?
  brand          String?
  category       String?
  stock          Int
  branchId       Int
  createdBy      String
  providerId     Int?
  imageUrl       String?         // URL de la imagen
  imagePublicId  String?         // ID público en Cloudinary
  isActive      Boolean  @default(true)
  deactivatedAt DateTime?
  deactivatedBy String?
  priceCurrency  String          @default("BOB")

  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [createdBy], references: [id])
  provider       Provider?       @relation(fields: [providerId], references: [id_provider])
  priceHistory   PriceHistory[]
  returnItems    ReturnItem[]
  saleItems      SaleItem[]
  stockMovements StockMovement[]
}

model PaymentMethod {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  isCash       Boolean       @default(false)
  expenses     Expense[]
  salePayments SalePayment[]
}

model CashBox {
  id            Int           @id @default(autoincrement())
  openedAt      DateTime      @default(now())
  closedAt      DateTime?
  openedBy      String
  closedBy      String?
  initialAmount Float
  closedAmount  Float?
  realClosedAmount  Float?
  expectedAmount    Float?
  difference        Float?
  observations      String?
  status        CashBoxStatus @default(OPEN)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  cashCount     Json?
  branchId      Int

  closedByUser  User?         @relation("CashBoxClosedBy", fields: [closedBy], references: [id])
  openedByUser  User          @relation("CashBoxOpenedBy", fields: [openedBy], references: [id])
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  expenses      Expense[]
  sales         Sale[]        @relation("box_sales")
}

model Sale {
  id             String          @id @default(uuid())
  sellerId       String
  clientId       Int?
  total          Float
  totalPaid      Float           @default(0)
  balance        Float           @default(0)
  paymentStatus  PaymentStatus   @default(PENDING)
  createdAt      DateTime        @default(now())
  cashBoxId      Int?
  branchId       Int
  createdBy      String?


  returns        Return[]
  items          SaleItem[]
  payments       SalePayment[]
  cashBox        CashBox?        @relation("box_sales", fields: [cashBoxId], references: [id])
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  client         Cliente?        @relation(fields: [clientId], references: [id_cliente])
  seller         User            @relation(fields: [sellerId], references: [id])
  stockMovements StockMovement[]
  commissions Commission[]

  @@map("sales")
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    String
  productId String
  quantity  Int
  unitPrice Float
  subtotal  Float
  originalPrice    Float?
  originalCurrency String?
  conversionRate   Float?

  product   Product @relation(fields: [productId], references: [id])
  sale      Sale    @relation(fields: [saleId], references: [id])

  @@map("sale_items")
}

model SalePayment {
  id              Int           @id @default(autoincrement())
  saleId          String
  paymentMethodId Int
  amount          Float
  cashBoxId       Int?
  createdAt       DateTime      @default(now())
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  sale            Sale          @relation(fields: [saleId], references: [id])

  @@map("sale_payments")
}

model Expense {
  id              Int           @id @default(autoincrement())
  cashBoxId       Int?
  amount          Float
  concept         String
  paymentMethodId Int
  createdAt       DateTime      @default(now())
  createdBy       String?
  branchId        Int

  user            User?         @relation(fields: [createdBy], references: [id])
  cashBox         CashBox?      @relation(fields: [cashBoxId], references: [id])
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model StockMovement {
  id            Int          @id @default(autoincrement())
  productId     String
  movementType  MovementType
  quantity      Int
  previousStock Int
  newStock      Int
  unitCost      Float?
  providerId    Int?
  saleId        String?
  notes         String?
  reason        String?
  createdBy     String
  createdAt     DateTime     @default(now())
  returnId      Int?
  isCompleted   Boolean      @default(false)
  completedAt   DateTime?
  completedBy   String?
  user          User         @relation(fields: [createdBy], references: [id])
  product       Product      @relation(fields: [productId], references: [id])
  provider      Provider?    @relation(fields: [providerId], references: [id_provider])
  return        Return?      @relation(fields: [returnId], references: [id], onDelete: Cascade)
  sale          Sale?        @relation(fields: [saleId], references: [id])

  @@map("stock_movements")
}

model PriceHistory {
  id        Int      @id @default(autoincrement())
  productId String
  oldPrice  Float
  newPrice  Float
  priceType String
  changedBy String
  changedAt DateTime @default(now())
  notes     String?
  user      User     @relation(fields: [changedBy], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@map("price_history")
}

model Return {
  id             Int             @id @default(autoincrement())
  saleId         String
  returnDate     DateTime        @default(now())
  reason         String
  approvedBy     String
  totalRefunded  Float
  refundMethod   String
  notes          String?
  status         ReturnStatus    @default(PENDING)
  items          ReturnItem[]
  user           User            @relation("ApprovedReturns", fields: [approvedBy], references: [id], onDelete: Cascade)
  sale           Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@map("returns")
}

model ReturnItem {
  id               Int     @id @default(autoincrement())
  returnId         Int
  productId        String
  quantityReturned Int
  unitPrice        Float
  subtotal         Float
  condition        String?
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  return           Return  @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@map("return_items")
}

model ExchangeRate {
  id           Int      @id @default(autoincrement())
  fromCurrency String
  toCurrency   String
  rate         Float
  source       String
  apiRate      Float?
  manualRate   Float?
  useManual    Boolean  @default(false)
  lastUpdated  DateTime @default(now())
  updatedBy    String?
  notes        String?

  @@unique([fromCurrency, toCurrency])
  @@map("exchange_rates")
}

model UserPreference {
  id                Int      @id @default(autoincrement())
  userId            String   @unique
  preferredCurrency String   @default("BOB")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])

  @@map("user_preferences")
}

model CommissionConfig {
  id          String          @id @default(uuid())
  type        CommissionType  @default(FIXED_AMOUNT)
  isActive    Boolean         @default(false)
  fixedAmount Float?          // Para comisiones fijas
  percentage  Float?          // Para comisiones porcentuales
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   String
  
  // Para comisiones por rangos (opcional)
  ranges      CommissionRange[]
  
  user        User            @relation(fields: [createdBy], references: [id])
}

model CommissionRange {
  id                Int     @id @default(autoincrement())
  configId          String
  minAmount         Float
  maxAmount         Float?
  commissionValue   Float   // Puede ser monto fijo o porcentaje según el type del padre
  commissionType    CommissionRangeType @default(FIXED)
  
  config            CommissionConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
}

model Commission {
  id          String    @id @default(uuid())
  saleId      String
  userId      String
  amount      Float
  calculatedAt DateTime @default(now())
  month       Int       // Mes de la comisión (1-12)
  year        Int       // Año de la comisión
  
  sale        Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])
  
  @@unique([saleId, userId]) // Una comisión única por venta y usuario
  @@map("commissions")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  @@index([token])
  @@map("password_reset_tokens")
}
model Branch {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  address     String?
  phone       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users      User[]
  products   Product[]
  sales      Sale[]
  cashBoxes  CashBox[]
  expenses   Expense[]
}

enum CommissionType {
  FIXED_AMOUNT     // Monto fijo por venta
  PERCENTAGE       // Porcentaje del total de venta
  TIERED_RANGES    // Rangos con diferentes comisiones
}

enum CommissionRangeType {
  FIXED      // Monto fijo dentro del rango
  PERCENTAGE // Porcentaje dentro del rango
}

enum Role {
  ADMIN
  SUPERVISOR
  SELLER
}

enum TipoCliente {
  PERSONA
  EMPRESA
}

enum CashBoxStatus {
  OPEN
  CLOSED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERPAID

  @@map("payment_status")
}

enum MovementType {
  PURCHASE
  SALE
  REPAIR_OUT
  REPAIR_RETURN
  DEMO_OUT
  DEMO_RETURN
  RETURN_IN
  ADJUSTMENT
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}
